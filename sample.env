# Outline API credentials
# -----------------------
# 1. Go to your Outline settings: https://app.getoutline.com/settings/api-keys
#    (or https://<your-instance>/settings/api-keys for self-hosted)
# 2. Create a new API key and paste it below
# 3. Run: outline auth credentials /path/to/this/file

OUTLINE_API_KEY=ol_api_replace_this_with_your_key

# Optional: only needed for self-hosted Outline instances.
# Defaults to https://app.getoutline.com/api when not set.
# OUTLINE_URL=https://your-outline-instance.com/api
